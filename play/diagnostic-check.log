              <button id="replayButton" class="secondary-button" type="button">Replay</button>
              <button id="shareButton" class="secondary-button" type="button">Share</button>
              <button id="nextButton" class="primary-button" type="button">Next expression</button>
              <button id="completionBackButton" class="secondary-button completion-back-button hidden" type="button">Back to Teddies</button>
            </div>
          </div>
        </section>
      </div>
    
      <div id="gameOverModal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="deadlockTitle">
        <section class="modal-card">
          <p class="eyebrow">NO CLEAR EXIT</p>
          <h3 id="deadlockTitle">No arrowhead currently has a clear lane.</h3>
          <button id="tryAgainButton" class="primary-button full" type="button">Restart expression</button>
        </section>
      </div>
    
      <div id="howToModal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="howToTitle">
        <section class="modal-card text-left">
          <p class="eyebrow">HOW TO PLAY</p>
          <h3 id="howToTitle">Pull the face apart one trail at a time.</h3>
          <ol class="instruction-list">
            <li>Tap an arrow trail whose arrowhead has a clear lane to the edge.</li>
            <li>The arrowhead exits first and the connected trail follows.</li>
            <li>A blocked trail stays in place and highlights the first visible blocker.</li>
            <li>Use Hint or Open arrow trails when you need a clear move.</li>
          </ol>
          <button id="closeHowToButton" class="primary-button full" type="button">Got it</button>
        </section>
      </div>
    
      <div id="settingsModal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="settingsTitle">
        <section class="modal-card text-left">
          <p class="eyebrow">SETTINGS</p>
          <h3 id="settingsTitle">Gameplay and accessibility</h3>
          <label class="setting-row">
            <span><strong>Reduced motion</strong><small>Shortens trail-removal movement.</small></span>
            <input id="reducedMotionToggle" type="checkbox" />
          </label>
          <label class="setting-row">
            <span><strong>High contrast</strong><small>Removes texture and strengthens path contrast.</small></span>
            <input id="highContrastToggle" type="checkbox" />
          </label>
          <label class="setting-row">
            <span><strong>Touch assistance</strong><small>Uses a larger invisible selection area.</small></span>
            <input id="touchAssistanceToggle" type="checkbox" />
          </label>
          <p id="buildInfo" class="build-info" aria-label="App build information">Checking app build…</p>
          <button id="closeSettingsButton" class="primary-button full" type="button">Done</button>
        </section>
      </div>
    
      <div id="accessibleMovesModal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="accessibleMovesTitle">
        <section class="modal-card text-left">
          <p class="eyebrow">OPEN TRAILS</p>
          <h3 id="accessibleMovesTitle">Choose a trail with a clear exit</h3>
          <p id="accessibleMovesSummary"></p>
          <div id="accessibleMovesList" class="accessible-moves-list" role="list"></div>
          <button id="closeAccessibleMovesButton" class="secondary-button full" type="button">Close</button>
        </section>
      </div>
    
      <script type="module" src="./src/app/bootstrap.js"></script>
    </body>
    </html>
    
